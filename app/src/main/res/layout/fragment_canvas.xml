<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- Drawing Canvas View -->

    <!-- Top Buttons Layout -->

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="404dp"
        android:layout_height="130dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="5dp"
        android:animateLayoutChanges="true"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/topButtonsLayout"
            android:layout_width="112dp"
            android:layout_height="118dp"
            android:layout_marginStart="10dp"
            android:layout_marginBottom="10dp"
            android:backgroundTint="#D32A2A"
            android:backgroundTintMode="add"
            android:orientation="vertical">

            <Button
                android:id="@+id/loadButton"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:layout_marginBottom="8dp"
                android:backgroundTint="#9567A8F2"
                android:text="Load Files"
                android:textAlignment="textStart"
                android:textSize="12sp" />

            <Button
                android:id="@+id/saveButton"
                android:layout_width="109dp"
                android:layout_height="48dp"
                android:backgroundTint="#505D89"
                android:fontFamily="monospace"
                android:text="Save"
                android:textAlignment="center"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:typeface="normal" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/penOptionsLayout"
            android:layout_width="116dp"
            android:layout_height="wrap_content"
            android:layerType="none"
            android:layoutDirection="ltr"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/sizeOptionsLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layerType="none"
                android:layoutDirection="ltr"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/sizeLabel"
                    android:layout_width="85dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="false"
                    android:paddingTop="8dp"
                    android:text="Size"
                    android:textAlignment="center"
                    android:textColor="#BF5555"
                    android:textSize="12sp" />

                <SeekBar
                    android:id="@+id/seekBar"
                    android:layout_width="111dp"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:contextClickable="true"
                    android:indeterminate="false"
                    android:max="50"
                    android:paddingStart="26dp"
                    android:progress="0"
                    android:progressTint="#35889E"
                    android:scaleX="1.25"
                    android:scaleY="1.25" />
            </LinearLayout>

            <TextView
                android:id="@+id/opacityLabel"
                android:layout_width="85dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="false"
                android:paddingTop="8dp"
                android:text="Opacity"
                android:textAlignment="center"
                android:textColor="#BF5555"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/opacityBar"
                android:layout_width="111dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:layout_weight="1"
                android:clickable="true"
                android:contextClickable="true"
                android:indeterminate="false"
                android:max="255"
                android:paddingStart="26dp"
                android:progress="0"
                android:progressTint="#35889E"
                android:scaleX="1.25"
                android:scaleY="1.25" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="166dp"
            android:layout_height="85dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/colorLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="false"
                android:fontFamily="@font/archivo_light"
                android:text="Color"
                android:typeface="serif" />

            <View
                android:id="@+id/divider2"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider" />

            <HorizontalScrollView
                android:id="@+id/colorScroller"
                android:layout_width="match_parent"
                android:layout_height="47dp"
                android:clickable="true">

                <LinearLayout
                    android:id="@+id/colorOptionsLayout"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/blackColorButton"
                        android:layout_width="20dp"
                        android:layout_height="29dp"
                        android:layout_margin="3dp"
                        android:backgroundTint="@color/black"
                        app:cornerRadius="3dp" />

                    <Button
                        android:id="@+id/redColorButton"
                        android:layout_width="20dp"
                        android:layout_height="29dp"
                        android:layout_margin="3dp"
                        android:backgroundTint="#FF0000"
                        app:cornerRadius="3dp" />

                    <Button
                        android:id="@+id/blueColorButton"
                        android:layout_width="20dp"
                        android:layout_height="29dp"
                        android:layout_margin="3dp"
                        android:backgroundTint="#0000FF"
                        app:cornerRadius="3dp" />

                    <Button
                        android:id="@+id/greenColorButton"
                        android:layout_width="20dp"
                        android:layout_height="29dp"
                        android:layout_margin="3dp"
                        android:backgroundTint="#00FF00"
                        app:cornerRadius="3dp" />

                    <Button
                        android:id="@+id/orangeColorButton"
                        android:layout_width="20dp"
                        android:layout_height="29dp"
                        android:layout_margin="3dp"
                        android:backgroundTint="#FFA500"
                        app:cornerRadius="3dp" />

                    <Button
                        android:id="@+id/customColorButton"
                        android:layout_width="22dp"
                        android:layout_height="40dp"
                        android:layout_margin="1dp"
                        android:backgroundTint="@android:color/darker_gray"
                        android:padding="0.5dp"
                        android:text="+"
                        android:textAlignment="center"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        app:cornerRadius="3dp" />
                </LinearLayout>
            </HorizontalScrollView>

        </LinearLayout>

    </LinearLayout>

    <com.example.drawingapp.DrawingView
        android:id="@+id/drawingCanvas"
        android:layout_width="407dp"
        android:layout_height="639dp"
        android:layout_marginStart="5dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="34dp"
        android:background="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.272"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout"
        app:layout_constraintVertical_bias="0.0" />

</androidx.constraintlayout.widget.ConstraintLayout>